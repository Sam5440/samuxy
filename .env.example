# Optional local overrides for samuxy Windows development.
# Copy this file to `.env` if you want to keep local values outside shell history.

# Override the desktop app data directory used by Electron tests and local runs.
SAMUXY_APP_DATA_DIR=

# Override where AI usage fixtures are read from.
SAMUXY_AI_USAGE_DIR=

# Override the update feed base URL.
SAMUXY_UPDATE_BASE_URL=

# Allow update checks in unpackaged development builds.
SAMUXY_FORCE_UPDATE_CHECK=

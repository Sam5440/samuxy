# Optional local overrides for samuxy Windows development.
# Copy this file to `.env` if you want to keep local values outside shell history.

# Override the desktop app data directory used by Electron tests and local runs.
SAMUXY_APP_DATA_DIR=

# Override where AI usage fixtures are read from.
SAMUXY_AI_USAGE_DIR=

# Override the local version file used by update checks.
SAMUXY_VERSION_FILE=

# Override the remote version endpoint for tests or private mirrors.
SAMUXY_REMOTE_VERSION_URL=

# Override the page opened when a newer version is available.
SAMUXY_REPOSITORY_URL=
